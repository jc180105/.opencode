# GitHub Personal Access Token
# Gere em: https://github.com/settings/tokens
# Permissoes necessarias: repo, read:org, workflow
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Linear
# Gere em: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — Multi-Projeto
# Para cada projeto: va em https://app.supabase.com/project/SEU_REF/settings/api
# e copie a "service_role" key (nao a anon key)
# Formato: SUPABASE_PROJECT_<NOME>_KEY=<service_role_key>
SUPABASE_PROJECT_MAIN_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxx
SUPABASE_PROJECT_DEMO_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxx

# Graphify — caminho do graph.json do projeto atual
# Mude para o projeto que estiver trabalhando
# Windows: D:\MeuProjeto\graphify-out\graph.json
# Linux/Mac: /home/user/project/graphify-out/graph.json
GRAPHIFY_GRAPH_PATH=graphify-out/graph.json